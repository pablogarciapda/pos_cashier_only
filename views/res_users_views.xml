<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_users_form_cashier_only" model="ir.ui.view">
        <field name="name">res.users.form.cashier.only</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="before">
                <field name="is_cashier_only" invisible="1"/>
                <div class="alert alert-info"
                     invisible="not is_cashier_only"
                     role="alert">
                    <strong>Cajero TPV restringido:</strong>
                    Este usuario solo puede acceder al TPV.
                    No ve el backend ni ningun menu administrativo.
                </div>
            </xpath>
            <xpath expr="//field[@name='login']" position="after">
                <field name="password" password="True" 
                       invisible="not is_cashier_only"
                       placeholder="Contraseña para acceso al TPV"/>
            </xpath>
        </field>
    </record>

    <record id="action_open_pos_home" model="ir.actions.server">
        <field name="name">Abrir TPV (Cajero)</field>
        <field name="model_id" ref="base.model_res_users"/>
        <field name="state">code</field>
        <field name="code">
action = {
    'type': 'ir.actions.act_url',
    'url': '/pos/cashier/select',
    'target': 'self',
}
        </field>
    </record>

    <record id="view_cashier_form" model="ir.ui.view">
        <field name="name">res.users.cashier.form</field>
        <field name="model">res.users</field>
        <field name="arch" type="xml">
            <form string="Cajero TPV">
                <sheet>
                    <field name="is_cashier_only" invisible="1"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Nombre del cajero"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Credenciales de acceso">
                            <field name="login" string="Usuario"/>
                            <field name="password" password="True" string="Contraseña"/>
                        </group>
                        <group string="Información de contacto">
                            <field name="email" string="Email"/>
                            <field name="phone" string="Teléfono"/>
                        </group>
                    </group>
                    <group string="Asignación a TPVs" invisible="not is_cashier_only"
                           col="4">
                        <p class="text-muted" colspan="4">
                            Selecciona los TPVs donde este cajero puede trabajar.
                            El empleado se agregará con derechos avanzados en cada TPV seleccionado
                            (podrá cerrar sesión y realizar todas las operaciones).
                        </p>
                    </group>
                    <group invisible="not is_cashier_only" col="4">
                        <field name="pos_config_ids" widget="many2many_tags" colspan="4" nolabel="1"
                               options="{'no_create': True, 'no_open': True}"
                               style="border: 1px solid #dee2e6; border-radius: 4px; padding: 8px; min-height: 36px; background: #fff;"/>
                    </group>
                    <div class="alert alert-info mt-3" role="alert" invisible="not is_cashier_only">
                        <strong>Nota:</strong> Este usuario solo podrá acceder al TPV.
                        No tendrá acceso al backend de Odoo.
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_cashier_tree" model="ir.ui.view">
        <field name="name">res.users.cashier.tree</field>
        <field name="model">res.users</field>
        <field name="arch" type="xml">
            <list string="Usuarios" decoration-success="is_cashier_only">
                <field name="is_cashier_only" widget="boolean" string="Es Cajero TPV"/>
                <field name="is_admin" invisible="1"/>
                <field name="name"/>
                <field name="login"/>
                <field name="email"/>
                <field name="phone"/>
                <button name="action_make_cashier" type="object" string="Hacer Cajero TPV" 
                        icon="fa-user-plus" invisible="is_cashier_only or is_admin"/>
                <button name="action_remove_cashier" type="object" string="Quitar Cajero TPV" 
                        icon="fa-user-times" invisible="not is_cashier_only"/>
            </list>
        </field>
    </record>

    <record id="action_cashier_only_users" model="ir.actions.act_window">
        <field name="name">Cajeros TPV</field>
        <field name="res_model">res.users</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('login', 'not in', ['admin', '__system__'])]</field>
        <field name="context">{'default_is_cashier_only': True}</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_cashier_tree')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_cashier_form')})]"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Gestiona los cajeros del TPV
            </p>
            <p>
                Selecciona usuarios y hazlos cajeros TPV con un clic.
                Los cajeros solo pueden acceder al TPV, sin acceso al backend.
            </p>
        </field>
    </record>

    <menuitem
        id="menu_pos_cashier_only_users"
        name="Cajeros (acceso restringido)"
        parent="point_of_sale.menu_point_config_product"
        action="action_cashier_only_users"
        sequence="50"
        groups="point_of_sale.group_pos_manager"/>
</odoo>
