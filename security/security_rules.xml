<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Regla de menú: bloquea TODOS los menús del backend -->
        <record id="ir_ui_menu_rule_pos_cashier" model="ir.rule">
            <field name="name">Cajero TPV no ve menús del backend</field>
            <field name="model_id" ref="base.model_ir_ui_menu"/>
            <field name="groups" eval="[(4, ref('pos_cashier_only.group_pos_cashier_only'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
            <field name="domain_force">[('id', '=', 0)]</field>
        </record>
    </data>
</odoo>
